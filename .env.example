# database connection used by JWT auth
# PostgreSQL connection (tương ứng với docker-compose.yml):
DB_URL=postgresql://postgres:postgres@localhost:5432/vr_supermarket_db

# JWT configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60

# server port
PORT=8080
